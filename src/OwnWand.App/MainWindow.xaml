<ui:FluentWindow x:Class="OwnWand.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:OwnWand.App"
        xmlns:models="clr-namespace:OwnWand.Core.Models;assembly=OwnWand.Core"
        xmlns:converters="clr-namespace:OwnWand.App.Converters"
        mc:Ignorable="d"
        Title="OwnWand" 
        Height="800" 
        Width="1200"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Background="{StaticResource BackgroundBrush}">

    <ui:FluentWindow.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:FeatureTypeToVisibilityConverter x:Key="FeatureTypeToVisibilityConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar: Game Library -->
            <ColumnDefinition Width="280" />
            <!-- Main Content Area -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Window Title Bar with close cross button -->
        <ui:TitleBar Title="OwnWand" 
                     Grid.Column="0" 
                     Grid.ColumnSpan="2" 
                     Height="32" 
                     VerticalAlignment="Top" />

        <!-- Sidebar -->
        <Border Grid.Column="0" 
                Background="{StaticResource SidebarGradientBrush}" 
                BorderBrush="{StaticResource SurfaceBorderBrush}" 
                BorderThickness="0,0,1,0">
            <Grid Margin="12,48,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Logo / Title -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,0,0,16">
                    <ui:SymbolIcon Symbol="Wand24" FontSize="28" Filled="True" Foreground="{StaticResource PrimaryBrush}" />
                    <TextBlock Text="OwnWand" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Margin="12,0,0,0" 
                               VerticalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#A855F7" Offset="0" />
                                <GradientStop Color="#00D2FF" Offset="1" />
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                </StackPanel>

                <!-- Search -->
                <ui:TextBox Grid.Row="1" 
                            PlaceholderText="Search games..." 
                            Icon="Search24"
                            Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                            Margin="4,0,4,12" />

                <!-- Game List -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding GameLibrary.Games}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:GameProfile}">
                                <Button Command="{Binding DataContext.SelectGameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Margin="0,2"
                                        Padding="8,6"
                                        Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Detected Indicator -->
                                        <Border Grid.Column="0" 
                                                Width="8" 
                                                Height="8" 
                                                CornerRadius="4" 
                                                VerticalAlignment="Center" 
                                                Margin="0,0,10,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDetected}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource SuccessBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsDetected}" Value="False">
                                                            <Setter Property="Background" Value="{StaticResource TextMutedBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <!-- Title -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" 
                                                       FontWeight="SemiBold" 
                                                       FontSize="14" 
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding Runtime}" 
                                                       FontSize="11" 
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </StackPanel>

                                        <!-- Attached Checkmark -->
                                        <ui:SymbolIcon Grid.Column="2" 
                                                       Symbol="CheckmarkCircle24" 
                                                       Filled="True" 
                                                       Foreground="{StaticResource AccentBrush}"
                                                       Visibility="{Binding IsAttached, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Custom game add -->
                <ui:Button Grid.Row="3" 
                        Command="{Binding OpenAddGameDialogCommand}"
                        Content="Add Custom Game" 
                        Icon="Add24"
                        HorizontalAlignment="Stretch"
                        Margin="4,12,4,4" />
            </Grid>
        </Border>

        <!-- Main Panel -->
        <Grid Grid.Column="1" Margin="24,48,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top Controls and Status -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left Info -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Games24" FontSize="32" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" />
                    <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedGame.Name, TargetNullValue='Select a game to start'}" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <!-- Runtime Badge -->
                            <Border Background="{StaticResource SurfaceBrush}" 
                                    BorderBrush="{StaticResource SurfaceBorderBrush}" 
                                    BorderThickness="1" 
                                    CornerRadius="4" 
                                    Padding="6,2"
                                    Visibility="{Binding SelectedGame, Converter={StaticResource NullToVisibilityConverter}}">
                                <TextBlock Text="{Binding SelectedGame.Runtime}" 
                                           FontSize="11" 
                                           FontWeight="SemiBold" 
                                           Foreground="{StaticResource AccentBrush}" />
                            </Border>
                            <!-- Connection Status -->
                            <TextBlock Text="{Binding StatusText}" 
                                       Margin="8,0,0,0" 
                                       FontSize="12" 
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Right Action Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Settings -->
                    <ui:Button Command="{Binding ToggleSettingsCommand}"
                            Appearance="Secondary"
                            Icon="Settings24"
                            Margin="0,0,8,0" />

                    <!-- Attach/Detach Trigger -->
                    <Grid>
                        <ui:Button Command="{Binding AttachToGameCommand}" 
                                Content="Attach Trainer" 
                                Appearance="Primary"
                                Icon="Play24"
                                Width="140"
                                Height="36">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AttachmentStatus}" Value="Connected">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedGame}" Value="{x:Null}">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedGame.IsDetected}" Value="False">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>
                        <ui:Button Command="{Binding DetachFromGameCommand}" 
                                Content="Detach" 
                                Appearance="Secondary"
                                Icon="Stop24"
                                Width="140"
                                Height="36">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AttachmentStatus}" Value="Connected">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Body Area -->
            <Grid Grid.Row="1">
                <!-- Cheat UI Panel -->
                <Grid Visibility="{Binding SelectedGame, Converter={StaticResource NullToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Profile Bar selector -->
                    <Border Grid.Row="0" 
                            Background="{StaticResource SurfaceBrush}" 
                            BorderBrush="{StaticResource SurfaceBorderBrush}" 
                            BorderThickness="1" 
                            CornerRadius="6" 
                            Padding="12,8"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" 
                                       Text="Profile:" 
                                       VerticalAlignment="Center" 
                                       FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextSecondaryBrush}" 
                                       Margin="0,0,12,0" />

                            <ComboBox Grid.Column="1" 
                                      ItemsSource="{Binding CheatPanel.Profiles}"
                                      SelectedItem="{Binding CheatPanel.SelectedProfile}"
                                      DisplayMemberPath="Name"
                                      VerticalAlignment="Center" />

                            <ui:Button Grid.Column="2" 
                                    Command="{Binding CheatPanel.DeleteProfileCommand}"
                                    CommandParameter="{Binding CheatPanel.SelectedProfile}"
                                    Icon="Delete24"
                                    Margin="8,0,0,0"
                                    Appearance="Transparent"
                                    Foreground="{StaticResource DangerBrush}"
                                    VerticalAlignment="Center" />

                            <!-- Create new profile -->
                            <TextBlock Grid.Column="4" 
                                       Text="New Profile:" 
                                       VerticalAlignment="Center" 
                                       Foreground="{StaticResource TextSecondaryBrush}" 
                                       Margin="0,0,8,0" />

                            <ui:TextBox Grid.Column="5" 
                                        Text="{Binding CheatPanel.NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="Profile name" 
                                        VerticalAlignment="Center" />

                            <ui:Button Grid.Column="6" 
                                    Command="{Binding CheatPanel.CreateProfileCommand}"
                                    Icon="Add24"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Feature Grid Cards -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CheatPanel.Features}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" VerticalAlignment="Top" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:CheatFeature}">
                                    <Border Style="{StaticResource GameTrainerCard}" Margin="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Metadata Info -->
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" 
                                                           FontWeight="Bold" 
                                                           FontSize="15" 
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Text="{Binding Description}" 
                                                           FontSize="12" 
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextSecondaryBrush}" 
                                                           Margin="0,4,12,8" />
                                                
                                                <!-- Slider (If slider type) -->
                                                <Grid Visibility="{Binding Type, Converter={StaticResource FeatureTypeToVisibilityConverter}, ConverterParameter=Slider}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Slider Grid.Column="0" 
                                                            Style="{StaticResource CheatSlider}"
                                                            Minimum="{Binding Min}" 
                                                            Maximum="{Binding Max}" 
                                                            Value="{Binding CurrentValue}"
                                                            TickFrequency="{Binding Step}"
                                                            IsSnapToTickEnabled="True"
                                                            VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" 
                                                               Text="{Binding CurrentValue, StringFormat='{}{0:0.0}x'}" 
                                                               FontSize="12" 
                                                               Margin="8,0,0,0" 
                                                               FontWeight="Bold" 
                                                               Foreground="{StaticResource AccentBrush}" 
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </StackPanel>

                                            <!-- Toggle Switch (If toggle type) -->
                                            <ToggleButton Grid.Column="1" 
                                                          Style="{StaticResource CheatToggleSwitch}"
                                                          IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                          Command="{Binding DataContext.CheatPanel.ToggleFeatureCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="{Binding}"
                                                          VerticalAlignment="Center"
                                                          Visibility="{Binding Type, Converter={StaticResource FeatureTypeToVisibilityConverter}, ConverterParameter=Toggle}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Settings overlay Panel -->
                <Border Background="{StaticResource BackgroundBrush}" 
                        BorderBrush="{StaticResource SurfaceBorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="24"
                        Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,24">
                            <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                            <ui:Button DockPanel.Dock="Right" 
                                    Command="{Binding ToggleSettingsCommand}"
                                    Icon="Dismiss24" 
                                    Appearance="Transparent"
                                    HorizontalAlignment="Right" />
                        </DockPanel>

                        <StackPanel Grid.Row="1">
                            <!-- Toggle Overlay -->
                            <DockPanel Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="In-Game Overlay" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Show UI inside the game window (DirectX overlay)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                                <ui:ToggleSwitch IsChecked="{Binding Settings.OverlayEnabled}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </DockPanel>

                            <!-- Toggle Auto Detect -->
                            <DockPanel Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Auto Detect Unity Games" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Scan running processes in background automatically" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                                <ui:ToggleSwitch IsChecked="{Binding Settings.AutoDetectGames}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </DockPanel>

                            <!-- Minimize to Tray -->
                            <DockPanel Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Minimize to System Tray" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Minimize app window to background system tray" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                                <ui:ToggleSwitch IsChecked="{Binding Settings.MinimizeToTray}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </DockPanel>

                            <!-- Custom Games Management -->
                            <Separator Margin="0,8,0,16" Background="{StaticResource SurfaceBorderBrush}" />
                            <TextBlock Text="Manage Custom Games" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12" />
                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Settings.CustomGames}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:CustomGameEntry}">
                                            <Border Background="{StaticResource SurfaceBrush}" 
                                                    BorderBrush="{StaticResource SurfaceBorderBrush}" 
                                                    BorderThickness="1" 
                                                    CornerRadius="6" 
                                                    Padding="12,8" 
                                                    Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" />
                                                        <TextBlock Text="{Binding ExePath}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <ui:Button Grid.Column="1" 
                                                               Command="{Binding DataContext.Settings.RemoveCustomGameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                               CommandParameter="{Binding Id}"
                                                               Icon="Delete24" 
                                                               Appearance="Transparent" 
                                                               Foreground="{StaticResource DangerBrush}" 
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
