{
    "id": "escape_the_backrooms",
    "name": "Escape the Backrooms",
    "processName": "Backrooms-Win64-Shipping",
    "steamAppId": 1943950,
    "runtime": "Unknown",
    "assemblyName": "Assembly-CSharp",
    "dataFolderPattern": "*_Data",
    "icon": "escape_the_backrooms.png",
    "categories": ["Horror", "Co-op", "Survival"],
    "features": [
        {
            "id": "god_mode",
            "category": "Player",
            "name": "God Mode",
            "description": "Prevents all damage from entities and hazards",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "pattern": "F3 0F 11 83 A0 01 00 00",
                "offset": 0,
                "patchBytes": "90 90 90 90 90 90 90 90"
            }
        },
        {
            "id": "infinite_stamina",
            "category": "Player",
            "name": "Infinite Stamina",
            "description": "Sprint and perform actions without depleting stamina",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "pattern": "F3 0F 11 83 30 01 00 00 F3",
                "offset": 0,
                "patchBytes": "90 90 90 90 90 90 90 90"
            }
        },
        {
            "id": "infinite_sanity",
            "category": "Player",
            "name": "Infinite Sanity",
            "description": "Sanity stays at maximum, preventing hallucinations and panic",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "SanityController",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "currentSanity",
                "value": "max"
            }
        },
        {
            "id": "enemies_cant_kill",
            "category": "Combat",
            "name": "Enemies Can't Kill",
            "description": "Entity attacks deal no lethal damage",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "EntityAI",
                "methodName": "AttackPlayer",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "invisibility",
            "category": "Combat",
            "name": "Invisibility",
            "description": "Entities cannot detect or chase you",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "EntityAI",
                "methodName": "DetectPlayer",
                "patchType": "Prefix",
                "action": "override_return",
                "value": "false"
            }
        },
        {
            "id": "speed_multiplier",
            "category": "Movement",
            "name": "Speed Multiplier",
            "description": "Multiplies overall player movement speed",
            "type": "slider",
            "defaultEnabled": false,
            "min": 1.0,
            "max": 10.0,
            "defaultValue": 1.0,
            "step": 0.5,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerMovement",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "multiply_field",
                "field": "moveSpeed",
                "value": "slider"
