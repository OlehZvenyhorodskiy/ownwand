{
    "id": "valheim",
    "name": "Valheim",
    "processName": "valheim",
    "steamAppId": 892970,
    "runtime": "Mono",
    "assemblyName": "assembly_valheim",
    "dataFolderPattern": "valheim_Data",
    "icon": "valheim.png",
    "categories": ["Survival", "Open World", "Co-op", "RPG", "Viking"],
    "features": [
        {
            "id": "god_mode",
            "category": "Player",
            "name": "God Mode",
            "description": "Prevents all damage to the player from enemies, falls, and environmental effects.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "Character",
                "methodName": "ApplyDamage",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "infinite_health",
            "category": "Player",
            "name": "Infinite Health",
            "description": "Keeps your health at maximum at all times.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "Character",
                "methodName": "UpdateHealth",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "m_health",
                "value": "max"
            }
        },
        {
            "id": "infinite_stamina",
            "category": "Player",
            "name": "Infinite Stamina",
            "description": "Prevents stamina from decreasing, allowing unlimited running, attacking, and swimming.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "Player",
                "methodName": "UseStamina",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "speed_multiplier",
            "category": "Movement",
            "name": "Speed Multiplier",
            "description": "Multiplies the player's movement speed by the specified factor.",
            "type": "slider",
            "defaultEnabled": false,
            "min": 1.0,
            "max": 10.0,
            "defaultValue": 1.0,
            "step": 0.5,
            "hookTarget": {
                "namespace": "",
                "className": "Character",
                "methodName": "UpdateMovementSpeed",
                "patchType": "Prefix",
                "action": "multiply_field",
                "field": "m_walkSpeed",
                "value": "slider"
            }
        },
        {
            "id": "jump_height",
            "category": "Movement",
            "name": "Jump Height",
            "description": "Multiplies the player's jump height by the specified factor.",
            "type": "slider",
            "defaultEnabled": false,
            "min": 1.0,
            "max": 10.0,
            "defaultValue": 1.0,
            "step": 0.5,
            "hookTarget": {
                "namespace": "",
                "className": "Character",
                "methodName": "Jump",
                "patchType": "Prefix",
                "action": "multiply_field",
                "field": "m_jumpForce",
                "value": "slider"
            }
        },
        {
            "id": "fly_mode",
            "category": "Movement",
            "name": "Fly Mode",
            "description": "Enables free flight, allowing the player to move in any direction.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "Character",
                "methodName": "UpdateGroundContact",
                "patchType": "Prefix",
                "action": "set_field",
                "field": "m_flying",
                "value": "true"
            }
        },
        {
            "id": "no_clip",
            "category": "Movement",
            "name": "No Clip",
            "description": "Disables collision detection so you can pass through walls and terrain.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "Character",
                "methodName": "UpdateGroundContact",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "m_noclip",
                "value": "true"
            }
        },
        {
            "id": "one_hit_kill",
            "category": "Combat",
            "name": "One Hit Kill",
            "description": "Kills any enemy with a single hit from any weapon.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "Character",
                "methodName": "Damage",
                "patchType": "Prefix",
                "action": "set_field",
                "field": "m_damage",
                "value": "999999"
            }
        },
        {
            "id": "infinite_weight",
            "category": "Resources",
            "name": "Infinite Weight Carry",
            "description": "Removes weight restrictions so you can carry unlimited items.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "Inventory",
                "methodName": "GetTotalWeight",
                "patchType": "Prefix",
                "action": "override_return",
                "value": "0"
            }
        },
        {
            "id": "no_skill_drain",
            "category": "Player",
            "name": "No Skill Drain",
            "description": "Prevents skills from losing progress on death.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "Skills",
                "methodName": "LowerAllSkills",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "infinite_resources",
            "category": "Resources",
            "name": "Infinite Resources",
            "description": "Resources are never consumed when building or crafting.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "Inventory",
                "methodName": "RemoveItem",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "no_weather_effects",
            "category": "World",
            "name": "No Weather Effects",
            "description": "Prevents rain, cold, and other weather effects from impacting the player.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "EnvMan",
                "methodName": "UpdateEnvironment",
                "patchType": "Prefix",
                "action": "set_field",
                "field": "m_wetTimer",
                "value": "0"
            }
        },
        {
            "id": "build_anywhere",
            "category": "World",
            "name": "Build Anywhere",
            "description": "Allows placing structures anywhere without a workbench or placement restrictions.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "Player",
                "methodName": "HaveRequirements",
                "patchType": "Prefix",
                "action": "override_return",
                "value": "true"
            }
        },
        {
            "id": "game_speed",
            "category": "World",
            "name": "Game Speed",
            "description": "Adjusts the overall game speed. Values below 1 slow down, values above 1 speed up.",
            "type": "slider",
            "defaultEnabled": false,
            "min": 0.1,
            "max": 5.0,
            "defaultValue": 1.0,
            "step": 0.1,
            "hookTarget": {
                "namespace": "UnityEngine",
                "className": "Time",
                "methodName": "set_timeScale",
                "patchType": "Prefix",
                "action": "override_return",
                "value": "slider"
            }
        }
    ]
}
