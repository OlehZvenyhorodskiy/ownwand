{
    "id": "subnautica",
    "name": "Subnautica",
    "processName": "Subnautica",
    "steamAppId": 264710,
    "runtime": "Mono",
    "assemblyName": "Assembly-CSharp",
    "dataFolderPattern": "Subnautica_Data",
    "icon": "subnautica.png",
    "categories": ["Survival", "Open World", "Underwater", "Adventure"],
    "features": [
        {
            "id": "god_mode",
            "category": "Player",
            "name": "God Mode",
            "description": "Prevents all damage to the player from creatures, environmental hazards, and pressure.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "LiveMixin",
                "methodName": "TakeDamage",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "infinite_health",
            "category": "Player",
            "name": "Infinite Health",
            "description": "Keeps your health at maximum at all times.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "LiveMixin",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "health",
                "value": "max"
            }
        },
        {
            "id": "infinite_oxygen",
            "category": "Player",
            "name": "Infinite Oxygen",
            "description": "Prevents oxygen from depleting so you can breathe underwater indefinitely.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "OxygenManager",
                "methodName": "RemoveOxygen",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "no_hunger",
            "category": "Player",
            "name": "No Hunger",
            "description": "Prevents hunger from increasing so you never need to eat.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "Survival",
                "methodName": "UpdateHunger",
                "patchType": "Prefix",
                "action": "set_field",
                "field": "food",
                "value": "max"
            }
        },
        {
            "id": "no_thirst",
            "category": "Player",
            "name": "No Thirst",
            "description": "Prevents thirst from increasing so you never need to drink.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "Survival",
                "methodName": "UpdateWater",
                "patchType": "Prefix",
                "action": "set_field",
                "field": "water",
                "value": "max"
            }
        },
        {
            "id": "speed_multiplier",
            "category": "Movement",
            "name": "Speed Multiplier",
            "description": "Multiplies the player's overall movement speed on land by the specified factor.",
            "type": "slider",
            "defaultEnabled": false,
            "min": 1.0,
            "max": 10.0,
            "defaultValue": 1.0,
            "step": 0.5,
            "hookTarget": {
                "namespace": "",
                "className": "GroundMotor",
                "methodName": "UpdateMove",
                "patchType": "Prefix",
                "action": "multiply_field",
                "field": "forwardMaxSpeed",
                "value": "slider"
            }
        },
        {
            "id": "fast_swim",
            "category": "Movement",
            "name": "Fast Swim",
            "description": "Multiplies your underwater swimming speed.",
            "type": "slider",
            "defaultEnabled": false,
            "min": 1.0,
            "max": 10.0,
            "defaultValue": 1.0,
            "step": 0.5,
            "hookTarget": {
                "namespace": "",
                "className": "UnderwaterMotor",
                "methodName": "UpdateMove",
                "patchType": "Prefix",
                "action": "multiply_field",
                "field": "swimSpeed",
                "value": "slider"
            }
        },
        {
            "id": "infinite_battery",
            "category": "Resources",
            "name": "Infinite Battery",
            "description": "Prevents batteries and power cells from losing charge.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "EnergyMixin",
                "methodName": "ConsumeEnergy",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "instant_build",
            "category": "World",
            "name": "Instant Build",
            "description": "Buildings and fabrication complete instantly without waiting.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "Constructable",
                "methodName": "GetConstructInterval",
                "patchType": "Prefix",
                "action": "override_return",
                "value": "0.001"
            }
        },
        {
            "id": "no_vehicle_damage",
            "category": "World",
            "name": "No Damage to Vehicles",
            "description": "Prevents all damage to vehicles including Seamoth, Cyclops, and Prawn Suit.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "Vehicle",
                "methodName": "OnTakeDamage",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "game_speed",
            "category": "World",
            "name": "Game Speed",
            "description": "Adjusts the overall game speed. Values below 1 slow down, values above 1 speed up.",
            "type": "slider",
            "defaultEnabled": false,
            "min": 0.1,
            "max": 5.0,
            "defaultValue": 1.0,
            "step": 0.1,
            "hookTarget": {
                "namespace": "UnityEngine",
                "className": "Time",
                "methodName": "set_timeScale",
                "patchType": "Prefix",
                "action": "override_return",
                "value": "slider"
            }
        }
    ]
}
