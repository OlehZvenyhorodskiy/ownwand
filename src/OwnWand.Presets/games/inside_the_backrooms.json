{
    "id": "inside_the_backrooms",
    "name": "Inside the Backrooms",
    "processName": "Inside the Backrooms",
    "steamAppId": 1603230,
    "runtime": "Mono",
    "assemblyName": "Assembly-CSharp",
    "dataFolderPattern": "*_Data",
    "icon": "inside_the_backrooms.png",
    "categories": ["Horror", "Co-op", "Survival"],
    "features": [
        {
            "id": "god_mode",
            "category": "Player",
            "name": "God Mode",
            "description": "Prevents all damage from entities and environmental hazards",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerStats",
                "methodName": "TakeDamage",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "infinite_stamina",
            "category": "Player",
            "name": "Infinite Stamina",
            "description": "Stamina never depletes when sprinting or performing actions",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerStats",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "stamina",
                "value": "max"
            }
        },
        {
            "id": "infinite_sanity",
            "category": "Player",
            "name": "Infinite Sanity",
            "description": "Sanity remains at maximum, preventing visual distortions and hallucinations",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerStats",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "sanity",
                "value": "max"
            }
        },
        {
            "id": "no_fall_damage",
            "category": "Player",
            "name": "No Fall Damage",
            "description": "Prevents damage from falling between levels",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerStats",
                "methodName": "ApplyFallDamage",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "speed_multiplier",
            "category": "Movement",
            "name": "Speed Multiplier",
            "description": "Multiplies overall player movement speed",
            "type": "slider",
            "defaultEnabled": false,
            "min": 1.0,
            "max": 10.0,
            "defaultValue": 1.0,
            "step": 0.5,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerMovement",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "multiply_field",
                "field": "moveSpeed",
                "value": "slider"
            }
        },
        {
            "id": "sprint_speed",
            "category": "Movement",
            "name": "Sprint Speed",
            "description": "Multiplies the sprint movement speed",
            "type": "slider",
            "defaultEnabled": false,
            "min": 1.0,
            "max": 10.0,
            "defaultValue": 1.0,
            "step": 0.5,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerMovement",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "multiply_field",
                "field": "sprintSpeed",
                "value": "slider"
            }
        },
        {
            "id": "crouch_speed",
            "category": "Movement",
            "name": "Crouch Speed",
            "description": "Multiplies the crouching movement speed",
            "type": "slider",
            "defaultEnabled": false,
            "min": 1.0,
            "max": 10.0,
            "defaultValue": 1.0,
            "step": 0.5,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerMovement",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "multiply_field",
                "field": "crouchSpeed",
                "value": "slider"
            }
        },
        {
            "id": "jump_height",
            "category": "Movement",
            "name": "Jump Height",
            "description": "Multiplies jump force for higher jumps",
            "type": "slider",
            "defaultEnabled": false,
            "min": 1.0,
            "max": 10.0,
            "defaultValue": 1.0,
            "step": 0.5,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerMovement",
                "methodName": "Jump",
                "patchType": "Prefix",
                "action": "multiply_field",
                "field": "jumpForce",
                "value": "slider"
            }
        },
        {
            "id": "fly_mode",
            "category": "Movement",
            "name": "Fly Mode",
            "description": "Fly freely through the levels, ignoring gravity",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerMovement",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "useGravity",
                "value": "false"
            }
        },
        {
            "id": "no_clip",
            "category": "Movement",
            "name": "No Clip",
            "description": "Walk through walls and solid objects to explore freely",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerMovement",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "noclipEnabled",
                "value": "true"
            }
        },
        {
            "id": "invisibility",
            "category": "Combat",
            "name": "Invisibility",
            "description": "Entities cannot detect or target the player",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "EntityAI",
                "methodName": "CanSeePlayer",
                "patchType": "Prefix",
                "action": "override_return",
                "value": "false"
            }
        },
        {
            "id": "night_vision",
            "category": "World",
            "name": "Night Vision",
            "description": "See clearly in all dark backrooms environments",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PostProcessingController",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "ambientIntensity",
                "value": "50000"
            }
        },
        {
            "id": "game_speed",
            "category": "World",
            "name": "Game Speed",
            "description": "Controls the overall game time scale",
            "type": "slider",
            "defaultEnabled": false,
            "min": 0.1,
            "max": 5.0,
            "defaultValue": 1.0,
            "step": 0.1,
            "hookTarget": {
                "namespace": "UnityEngine",
                "className": "Time",
                "methodName": "set_timeScale",
                "patchType": "Prefix",
                "action": "override_return",
                "value": "slider"
            }
        }
    ]
}
