{
    "id": "gang_beasts",
    "name": "Gang Beasts",
    "processName": "GangBeasts",
    "steamAppId": 285900,
    "runtime": "Mono",
    "assemblyName": "Assembly-CSharp",
    "dataFolderPattern": "GangBeasts_Data",
    "icon": "gang_beasts.png",
    "categories": ["Fighting", "Physics", "Party", "Co-op"],
    "features": [
        {
            "id": "god_mode",
            "category": "Player",
            "name": "God Mode",
            "description": "Prevents being knocked out or eliminated, making you unkillable.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerHealth",
                "methodName": "TakeDamage",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "infinite_health",
            "category": "Player",
            "name": "Infinite Health",
            "description": "Keeps your health at maximum, preventing stagger and knockouts.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerHealth",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "health",
                "value": "max"
            }
        },
        {
            "id": "no_knockout",
            "category": "Player",
            "name": "No Knockout",
            "description": "Prevents your character from being knocked unconscious.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerHealth",
                "methodName": "KnockOut",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "super_strength",
            "category": "Combat",
            "name": "Super Strength",
            "description": "Greatly increases the force of your punches and grabs.",
            "type": "slider",
            "defaultEnabled": false,
            "min": 1.0,
            "max": 50.0,
            "defaultValue": 5.0,
            "step": 1.0,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerCombat",
                "methodName": "Punch",
                "patchType": "Prefix",
                "action": "multiply_field",
                "field": "punchForce",
                "value": "slider"
            }
        },
        {
            "id": "speed_multiplier",
            "category": "Movement",
            "name": "Speed Multiplier",
            "description": "Multiplies the player's movement speed by the specified factor.",
            "type": "slider",
            "defaultEnabled": false,
            "min": 1.0,
            "max": 10.0,
            "defaultValue": 1.0,
            "step": 0.5,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerMovement",
                "methodName": "Move",
                "patchType": "Prefix",
                "action": "multiply_field",
                "field": "moveSpeed",
                "value": "slider"
            }
        },
        {
            "id": "super_jump",
            "category": "Movement",
            "name": "Super Jump",
            "description": "Enables an extremely high jump that launches your character far into the air.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerMovement",
                "methodName": "Jump",
                "patchType": "Prefix",
                "action": "set_field",
                "field": "jumpForce",
                "value": "100"
            }
        },
        {
            "id": "game_speed",
            "category": "World",
            "name": "Game Speed",
            "description": "Adjusts the overall game speed. Values below 1 slow down, values above 1 speed up.",
            "type": "slider",
            "defaultEnabled": false,
            "min": 0.1,
            "max": 5.0,
            "defaultValue": 1.0,
            "step": 0.1,
            "hookTarget": {
                "namespace": "UnityEngine",
                "className": "Time",
                "methodName": "set_timeScale",
                "patchType": "Prefix",
                "action": "override_return",
                "value": "slider"
            }
        }
    ]
}
