{
    "id": "repo",
    "name": "R.E.P.O.",
    "processName": "REPO",
    "steamAppId": 3241660,
    "runtime": "Mono",
    "assemblyName": "Assembly-CSharp",
    "dataFolderPattern": "*_Data",
    "icon": "repo.png",
    "categories": ["Horror", "Co-op", "Survival"],
    "features": [
        {
            "id": "god_mode",
            "category": "Player",
            "name": "God Mode",
            "description": "Prevents all damage from any source",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerHealth",
                "methodName": "TakeDamage",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "infinite_health",
            "category": "Player",
            "name": "Infinite Health",
            "description": "Keeps player health at maximum value",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerHealth",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "health",
                "value": "max"
            }
        },
        {
            "id": "infinite_stamina",
            "category": "Player",
            "name": "Infinite Stamina",
            "description": "Stamina never decreases when sprinting or performing actions",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerController",
                "methodName": "UpdateStamina",
                "patchType": "Prefix",
                "action": "set_field",
                "field": "stamina",
                "value": "max"
            }
        },
        {
            "id": "infinite_oxygen",
            "category": "Player",
            "name": "Infinite Oxygen",
            "description": "Oxygen never depletes in hazardous environments",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerController",
                "methodName": "UpdateOxygen",
                "patchType": "Prefix",
                "action": "set_field",
                "field": "oxygen",
                "value": "max"
            }
        },
        {
            "id": "no_fall_damage",
            "category": "Player",
            "name": "No Fall Damage",
            "description": "Prevents damage from falling any height",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerHealth",
                "methodName": "ApplyFallDamage",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "speed_multiplier",
            "category": "Movement",
            "name": "Speed Multiplier",
            "description": "Multiplies overall player movement speed",
            "type": "slider",
            "defaultEnabled": false,
            "min": 1.0,
            "max": 10.0,
            "defaultValue": 1.0,
            "step": 0.5,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerController",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "multiply_field",
                "field": "moveSpeed",
                "value": "slider"
            }
        },
        {
            "id": "sprint_speed_multiplier",
            "category": "Movement",
            "name": "Sprint Speed Multiplier",
            "description": "Multiplies sprint speed independently of walk speed",
            "type": "slider",
            "defaultEnabled": false,
            "min": 1.0,
            "max": 10.0,
            "defaultValue": 1.0,
            "step": 0.5,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerController",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "multiply_field",
                "field": "sprintSpeed",
                "value": "slider"
            }
        },
        {
            "id": "jump_height",
            "category": "Movement",
            "name": "Jump Height",
            "description": "Multiplies jump force for higher jumps",
            "type": "slider",
            "defaultEnabled": false,
            "min": 1.0,
            "max": 10.0,
            "defaultValue": 1.0,
            "step": 0.5,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerController",
                "methodName": "Jump",
                "patchType": "Prefix",
                "action": "multiply_field",
                "field": "jumpForce",
                "value": "slider"
            }
        },
        {
            "id": "fly_mode",
            "category": "Movement",
            "name": "Fly Mode",
            "description": "Allows free flight movement ignoring gravity",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerController",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "useGravity",
                "value": "false"
            }
        },
        {
            "id": "no_clip",
            "category": "Movement",
            "name": "No Clip",
            "description": "Walk through walls and solid objects",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerController",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "noclipActive",
                "value": "true"
            }
        },
        {
            "id": "invisibility",
            "category": "Combat",
            "name": "Invisibility",
            "description": "Enemies cannot detect or target you",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "EnemyAI",
                "methodName": "CheckLineOfSight",
                "patchType": "Prefix",
                "action": "override_return",
                "value": "false"
            }
        },
        {
            "id": "one_hit_kill",
            "category": "Combat",
            "name": "One Hit Kill",
            "description": "Kill any enemy with a single hit",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "EnemyHealth",
                "methodName": "TakeDamage",
                "patchType": "Prefix",
                "action": "set_field",
                "field": "health",
                "value": "0"
            }
        },
        {
            "id": "game_speed",
            "category": "World",
            "name": "Game Speed",
            "description": "Controls the overall game time scale",
            "type": "slider",
            "defaultEnabled": false,
            "min": 0.1,
            "max": 5.0,
            "defaultValue": 1.0,
            "step": 0.1,
            "hookTarget": {
                "namespace": "UnityEngine",
                "className": "Time",
                "methodName": "set_timeScale",
                "patchType": "Prefix",
                "action": "override_return",
                "value": "slider"
            }
        },
        {
            "id": "infinite_battery",
            "category": "Resources",
            "name": "Infinite Battery",
            "description": "Flashlights and equipment never run out of battery",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "FlashlightController",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "batteryLife",
                "value": "max"
            }
        },
        {
            "id": "infinite_money",
            "category": "Resources",
            "name": "Infinite Money",
            "description": "Sets player currency to a very high value",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "GameManager",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "currency",
                "value": "999999"
            }
        }
    ]
}
