{
    "id": "ghost_watchers",
    "name": "Ghost Watchers",
    "processName": "Ghost Watchers",
    "steamAppId": 1850740,
    "runtime": "Mono",
    "assemblyName": "Assembly-CSharp",
    "dataFolderPattern": "*_Data",
    "icon": "ghost_watchers.png",
    "categories": ["Horror", "Co-op", "Investigation"],
    "features": [
        {
            "id": "god_mode",
            "category": "Player",
            "name": "God Mode",
            "description": "Prevents all damage from ghost attacks and hazards",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerHealth",
                "methodName": "TakeDamage",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "infinite_health",
            "category": "Player",
            "name": "Infinite Health",
            "description": "Keeps player health at maximum at all times",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerHealth",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "health",
                "value": "max"
            }
        },
        {
            "id": "infinite_sanity",
            "category": "Player",
            "name": "Infinite Sanity",
            "description": "Sanity remains at maximum, preventing fear effects and ghost aggression",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerSanity",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "currentSanity",
                "value": "max"
            }
        },
        {
            "id": "speed_multiplier",
            "category": "Movement",
            "name": "Speed Multiplier",
            "description": "Multiplies player movement speed",
            "type": "slider",
            "defaultEnabled": false,
            "min": 1.0,
            "max": 10.0,
            "defaultValue": 1.0,
            "step": 0.5,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerController",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "multiply_field",
                "field": "moveSpeed",
                "value": "slider"
            }
        },
        {
            "id": "infinite_battery",
            "category": "Resources",
            "name": "Infinite Battery",
            "description": "Flashlight and ghost detection equipment never run out of battery",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "EquipmentBase",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "batteryCharge",
                "value": "max"
            }
        },
        {
            "id": "night_vision",
            "category": "World",
            "name": "Night Vision",
            "description": "See clearly in all dark environments without a flashlight",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "LightingController",
                "methodName": "Update",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "ambientIntensity",
                "value": "50000"
            }
        },
        {
            "id": "invisibility",
            "category": "Combat",
            "name": "Invisibility",
            "description": "Ghost cannot detect or target you during hunts",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "GhostAI",
                "methodName": "CanSeePlayer",
                "patchType": "Prefix",
                "action": "override_return",
                "value": "false"
            }
        },
        {
            "id": "game_speed",
            "category": "World",
            "name": "Game Speed",
            "description": "Controls the overall game time scale",
            "type": "slider",
            "defaultEnabled": false,
            "min": 0.1,
            "max": 5.0,
            "defaultValue": 1.0,
            "step": 0.1,
            "hookTarget": {
                "namespace": "UnityEngine",
                "className": "Time",
                "methodName": "set_timeScale",
                "patchType": "Prefix",
                "action": "override_return",
                "value": "slider"
            }
        }
    ]
}
