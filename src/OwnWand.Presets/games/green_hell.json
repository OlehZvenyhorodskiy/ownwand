{
    "id": "green_hell",
    "name": "Green Hell",
    "processName": "GreenHell",
    "steamAppId": 815370,
    "runtime": "Mono",
    "assemblyName": "Assembly-CSharp",
    "dataFolderPattern": "GreenHell_Data",
    "icon": "green_hell.png",
    "categories": ["Survival", "Open World", "Simulation", "Horror"],
    "features": [
        {
            "id": "god_mode",
            "category": "Player",
            "name": "God Mode",
            "description": "Prevents all damage to the player from enemies, falls, infections, and environmental hazards.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerConditionModule",
                "methodName": "TakeDamage",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "infinite_health",
            "category": "Player",
            "name": "Infinite Health",
            "description": "Keeps your health at maximum at all times.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerConditionModule",
                "methodName": "UpdateHealth",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "m_HP",
                "value": "max"
            }
        },
        {
            "id": "infinite_stamina",
            "category": "Player",
            "name": "Infinite Stamina",
            "description": "Prevents stamina from decreasing, allowing unlimited sprinting and actions.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerConditionModule",
                "methodName": "UpdateStamina",
                "patchType": "Prefix",
                "action": "set_field",
                "field": "m_Stamina",
                "value": "max"
            }
        },
        {
            "id": "no_hunger",
            "category": "Player",
            "name": "No Hunger",
            "description": "Prevents hunger from increasing so you never need to eat.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerConditionModule",
                "methodName": "UpdateNutrition",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "m_NutritionFat",
                "value": "max"
            }
        },
        {
            "id": "no_thirst",
            "category": "Player",
            "name": "No Thirst",
            "description": "Prevents thirst from increasing so you never need to drink.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerConditionModule",
                "methodName": "UpdateHydration",
                "patchType": "Postfix",
                "action": "set_field",
                "field": "m_Hydration",
                "value": "max"
            }
        },
        {
            "id": "no_sanity_loss",
            "category": "Player",
            "name": "No Sanity Loss",
            "description": "Prevents sanity from decreasing, avoiding hallucinations and psychological effects.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "PlayerConditionModule",
                "methodName": "UpdateSanity",
                "patchType": "Prefix",
                "action": "set_field",
                "field": "m_Sanity",
                "value": "max"
            }
        },
        {
            "id": "no_parasites",
            "category": "Player",
            "name": "No Parasites",
            "description": "Prevents parasites from infecting the player.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "ParasiteSickness",
                "methodName": "Activate",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "no_infections",
            "category": "Player",
            "name": "No Infections",
            "description": "Prevents wound infections and diseases from occurring.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "Disease",
                "methodName": "Activate",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "speed_multiplier",
            "category": "Movement",
            "name": "Speed Multiplier",
            "description": "Multiplies the player's movement speed by the specified factor.",
            "type": "slider",
            "defaultEnabled": false,
            "min": 1.0,
            "max": 10.0,
            "defaultValue": 1.0,
            "step": 0.5,
            "hookTarget": {
                "namespace": "",
                "className": "FPPController",
                "methodName": "UpdateMovement",
                "patchType": "Prefix",
                "action": "multiply_field",
                "field": "m_WalkSpeed",
                "value": "slider"
            }
        },
        {
            "id": "infinite_items",
            "category": "Resources",
            "name": "Infinite Items",
            "description": "Items and resources are never consumed from your inventory when used or crafted.",
            "type": "toggle",
            "defaultEnabled": false,
            "hookTarget": {
                "namespace": "",
                "className": "InventoryBackpack",
                "methodName": "RemoveItem",
                "patchType": "Prefix",
                "action": "skip"
            }
        },
        {
            "id": "game_speed",
            "category": "World",
            "name": "Game Speed",
            "description": "Adjusts the overall game speed. Values below 1 slow down, values above 1 speed up.",
            "type": "slider",
            "defaultEnabled": false,
            "min": 0.1,
            "max": 5.0,
            "defaultValue": 1.0,
            "step": 0.1,
            "hookTarget": {
                "namespace": "UnityEngine",
                "className": "Time",
                "methodName": "set_timeScale",
                "patchType": "Prefix",
                "action": "override_return",
                "value": "slider"
            }
        }
    ]
}
